PORT=3001
LAVA_API_KEY=

# Google OAuth + Gmail drafts — create OAuth client in Google Cloud Console (Web application).
# Redirect URI must match exactly (Console + here).
# If you see invalid_client: regenerate the client secret in Credentials and update both lines (same client).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
